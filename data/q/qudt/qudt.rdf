    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">dbpedia match</rdfs:label>
    <rdfs:range rdf:resource="&xsd;anyURI" />
  </owl:DatatypeProperty>
