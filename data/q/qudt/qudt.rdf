  <owl:ObjectProperty rdf:about="&qudt;baseDimensionEnumeration">
    <dcterms:description rdf:datatype="&rdf;HTML">This property associates a system of quantities with an enumeration that enumerates the base dimensions of the system in canonical order.</dcterms:description>
    <rdf:type rdf:resource="&owl;FunctionalProperty" />
