  <owl:ObjectProperty rdf:about="&qudt;applicableSystem">
    <dcterms:description rdf:datatype="&xsd;string">
  This property relates a unit of measure with a unit system that may or may not define the unit,
   but within which the unit is compatible.
  </dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">applicable system</rdfs:label>
    <rdfs:range rdf:resource="&qudt;SystemOfUnits" />
  </owl:ObjectProperty>
