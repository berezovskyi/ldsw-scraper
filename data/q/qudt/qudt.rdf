  </owl:Class>
  <owl:Class rdf:about="&qudt;BaseDimensionMagnitude">
    <dcterms:description rdf:datatype="&rdf;HTML">
  &lt;p&gt;A &lt;em&gt;Dimension&lt;/em&gt; expresses a magnitude for a base quantity kind such as mass, length and time.
  &lt;/p&gt;
  &lt;p&gt;DEPRECATED - each exponent is expressed as a property. 
  Keep until a validation of this has been done.
  &lt;/p&gt;</dcterms:description>
    <qudt:informativeReference rdf:datatype="&xsd;anyURI">http://web.mit.edu/2.25/www/pdf/DA_unified.pdf</qudt:informativeReference>
    <qudt:informativeReference rdf:datatype="&xsd;anyURI">https://en.wikipedia.org/wiki/Dimensional_analysis</qudt:informativeReference>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">Base Dimension Magnitude</rdfs:label>
    <rdfs:subClassOf rdf:resource="&qudt;Concept" />
    <rdfs:subClassOf rdf:nodeID="autos139" />
    <rdfs:subClassOf rdf:nodeID="autos140" />
    <rdfs:subClassOf rdf:nodeID="autos141" />
    <rdfs:subClassOf rdf:nodeID="autos142" />
    <rdfs:subClassOf rdf:nodeID="autos143" />
    <rdfs:subClassOf rdf:nodeID="autos144" />
    <rdfs:subClassOf rdf:nodeID="autos145" />
    <rdfs:subClassOf rdf:nodeID="autos146" />
  </owl:Class>
  <owl:Class rdf:about="&qudt;BinaryPrefix">
    <dcterms:description rdf:datatype="&rdf;HTML">
  &lt;p&gt;A &lt;em&gt;Binary Prefix&lt;/em&gt; is a prefix for multiples of units in data processing, data transmission, and digital information,
   notably the bit and the byte, to indicate multiplication by a power of 2.
   &lt;/p&gt;
  </dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">Binary Prefix</rdfs:label>
    <rdfs:subClassOf rdf:resource="&qudt;Prefix" />
  </owl:Class>
  <owl:Class rdf:about="&qudt;Citation">
    <dcterms:description rdf:datatype="&rdf;HTML">Provides a simple way of making citations.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">Citation</rdfs:label>
    <rdfs:subClassOf rdf:resource="&qudt;Concept" />
    <rdfs:subClassOf rdf:nodeID="autos147" />
