  <owl:Class rdf:about="&qudt;Aspect">
    <dcterms:description rdf:datatype="&rdf;HTML">An aspect is an abstract type class that defines properties that can be reused.</dcterms:description>
    <rdf:type rdf:resource="&qudt;AspectClass" />
