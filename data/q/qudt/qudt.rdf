    <rdf:type rdf:resource="&owl;FunctionalProperty" />
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">data structure</rdfs:label>
    <rdfs:range rdf:resource="&xsd;string" />
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="&qudt;datatype">
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/datatype" />
  </owl:ObjectProperty>
