    <dcterms:description rdf:datatype="&rdf;HTML">The default element in an enumeration</dcterms:description>
    <rdf:type rdf:resource="&owl;FunctionalProperty" />
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">default</rdfs:label>
    <rdfs:range rdf:resource="&qudt;EnumeratedValue" />
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="&qudt;definedUnitOfSystem">
    <dcterms:description rdf:datatype="&rdf;HTML">This property relates a unit of measure with the unit system that defines the unit.</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">defined unit of system</rdfs:label>
    <rdfs:range rdf:resource="&qudt;SystemOfUnits" />
    <rdfs:subPropertyOf rdf:resource="&qudt;isUnitOfSystem" />
    <owl:inverseOf rdf:resource="&qudt;hasDefinedUnit" />
  </owl:ObjectProperty>
