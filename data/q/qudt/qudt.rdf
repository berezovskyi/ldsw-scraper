    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">applicable US Customary unit</rdfs:label>
    <rdfs:range rdf:resource="&qudt;Unit" />
    <rdfs:subPropertyOf rdf:resource="&qudt;applicableUnit" />
  </owl:ObjectProperty>
  <owl:ObjectProperty rdf:about="&qudt;applicableUnit">
    <dcterms:description rdf:datatype="&rdf;HTML">
  &lt;p&gt;See this page on the QUDT GitHub&lt;a href="https://github.com/qudt/qudt-public-repo/wiki/Advanced-User-Guide#4-computing-applicable-units-for-a-quantitykind"&gt;Wiki&lt;/a&gt;
   on how "qudt:applicableUnit" is computed from "qudt:hasQuantityKind" and then materialized.
  &lt;/p&gt;</dcterms:description>
    <rdfs:isDefinedBy rdf:resource="http://qudt.org/schema/qudt" />
    <rdfs:label rdf:datatype="&xsd;string">applicable unit</rdfs:label>
    <rdfs:range rdf:resource="&qudt;Unit" />
  </owl:ObjectProperty>
