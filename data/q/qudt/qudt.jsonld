  {
    "@id": "http://qudt.org/schema/qudt/CountingUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Counting Unit</em> is used for all units that express counts. \n  Examples are Atomic Number, Number, Number per Year, Percent and Sample per Second.\n  </p>\n  ",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Counting Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/DimensionlessUnit"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/CurrencyUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  Currency Units have their own subclass of unit because:\n   (a) they have additional properties such as 'country' and\n   (b) their URIs do not conform to the same rules as other units.\n  ",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Currency Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/DimensionlessUnit"
      },
      {
        "@id": "_:autos327"
      },
      {
        "@id": "_:autos328"
      },
      {
        "@id": "_:autos329"
      }
    ]
  },
  {
    "@id": "_:autos327",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/currencyExponent"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/currencyExponent",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  The currency exponent indicates the number of decimal places between a major currency unit and its minor currency unit. \n  For example, the US dollar is the major currency unit of the United States, and the US cent is the minor currency unit. Since one cent is 1/100 of a dollar, the US dollar has a currency exponent of 2. \n  However, the Japanese Yen has no minor currency units, so the yen has a currency exponent of 0.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "currency exponent"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#integer"
      }
    ]
  },
  {
    "@id": "_:autos328",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/currencyCode"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/currencyCode",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "Alphabetic Currency Code as defined by ISO 4217. For example, the currency code for the US dollar is USD.",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "currency code"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ]
  },
  {
    "@id": "_:autos329",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/currencyNumber"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/currencyNumber",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "Three-digit Currency Code as defined by ISO 4217. For example, the currency number for the US dollar is \"840\".",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "currency number"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2001/XMLSchema#string"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/DataItem",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Data Item</em> holds a value that maybe a scalar or structured datatype.\n  <em>Quantity Value</em> specifies which case applies.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Data Item"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
      {
