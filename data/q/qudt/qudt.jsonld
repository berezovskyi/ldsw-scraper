  {
    "@id": "http://qudt.org/schema/qudt/FactorUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Factor Unit</em> is a type specification for a unit, exponent pair that is a component of a derived unit.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://qudt.org/schema/qudt/dbpediaMatch": [
      {
        "@value": "http://dbpedia.org/resource/Category:SI_derived_units",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Factor Unit"
      },
      {
        "@value": "Reified Factor"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
      {
        "@id": "_:autos352"
      },
      {
        "@id": "_:autos353"
      },
      {
        "@id": "_:autos354"
      }
    ]
  },
  {
    "@id": "_:autos352",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#minCardinality": [
      {
        "@value": "1",
        "@type": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasUnit"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/hasUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>This property relates a factor unit to its unit or system of units with a unit of measure that is either:\n  </p>\n  <dl>\n  <dd>a) defined by the system,</dd>\n  <dd>b) accepted for use by the system and is convertible to a unit of equivalent dimension that is defined by the system,</dd>\n  <dd>c) a reference to the unit of measure of a quantity (variable or constant) of interest.</dd>\n  </dl>\n  <p>Systems of units may distinguish between base and derived units.\n  Base units are the units which measure the base quantities for the corresponding system of quantities. \n  The base units are used to define units for all other quantities as products of powers of the base units. \n  Such units are called derived units for the system. \n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "has unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ]
  },
  {
    "@id": "_:autos353",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#maxCardinality": [
      {
        "@value": "1",
        "@type": "http://www.w3.org/2001/XMLSchema#nonNegativeInteger"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasUnit"
      }
    ]
  },
