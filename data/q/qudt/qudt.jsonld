  {
    "@id": "http://qudt.org/schema/qudt/LogarithmicUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  Logarithmic units are abstract mathematical units that can be used to express any quantities\n   (physical or mathematical) that are defined on a logarithmic scale, that is, as being proportional\n   to the value of a logarithm function.\n  Examples of logarithmic units include common units of information and entropy, such as the bit,\n   and the byte, as well as units of relative signal strength magnitude such as the decibel.\n  ",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Logarithmic Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/DimensionlessUnit"
      }
    ]
  },
