  {
    "@id": "http://qudt.org/schema/qudt/QuantityKind",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Quantity Kind</em> is any observable property that can be  measured and quantified numerically. \n  Familiar examples include physical properties such as length, mass, time, force, energy, power, electric charge, etc. \n  Less familiar examples include currency, interest rate, price to earning ratio, and information capacity.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://qudt.org/schema/qudt/informativeReference": [
      {
        "@value": "http://www.electropedia.org/iev/iev.nsf/display?openform&ievref=112-01-04",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Quantity Kind"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/AbstractQuantityKind"
      },
      {
        "@id": "http://qudt.org/schema/qudt/Verifiable"
      },
