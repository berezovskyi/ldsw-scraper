  {
    "@id": "http://qudt.org/schema/qudt/PhysicalConstant",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Physical constant</em> is a physical quantity that is generally believed to be both universal in nature and constant in time. \n  It can be contrasted with a mathematical constant, which is a fixed numerical value but does not directly involve any physical measurement. \n  </p>\n  <p>There are many physical constants in science, some of the most widely recognized being:\n   the speed of light in vacuum c, Newton's gravitational constant G, Planck's constant h,\n   the electric permittivity of free space ε0, and the elementary charge e.\n  </p>\n  <p>Physical constants can take many dimensional forms, or may be dimensionless depending on the system of quantities and units used.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://qudt.org/schema/qudt/dbpediaMatch": [
      {
        "@value": "http://dbpedia.org/resource/Physical_constant",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Physical Constant"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Quantity"
      },
      {
        "@id": "_:autos389"
      },
      {
        "@id": "_:autos390"
      },
      {
        "@id": "_:autos391"
