    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  This property relates a unit system with a unit of measure that is not defined by or part of the system,\n   but is allowed for use within the system.\n   An allowed unit must be convertible to some dimensionally eqiuvalent unit that is defined by the system.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "allowed unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://qudt.org/schema/qudt/hasUnit"
      }
    ]
  },
  {
    "@id": "_:autos548",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasBaseUnit"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/hasBaseUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  This property relates a system of units to a base unit defined within the system.\n  The base units of a system are used to define the derived units of the system by expressing\n   the derived units as products of the base units raised to a rational power.\n  "
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://qudt.org/schema/qudt/baseUnitOfSystem"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "base unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://qudt.org/schema/qudt/hasCoherentUnit"
      }
    ]
  },
  {
    "@id": "_:autos551",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasDerivedUnit"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/hasDerivedUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  This property relates a system of units to a unit of measure that is defined within the system in terms\n   of the base units for the system. \n  That is, the derived unit is defined as a product of the base units for the system raised to some rational power.\n  "
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://qudt.org/schema/qudt/derivedUnitOfSystem"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "derived unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ]
  },
  {
    "@id": "_:autos552",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasCoherentUnit"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/hasCoherentUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#ObjectProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  A coherent unit of measurement for a unit system is a defined unit that may be expressed as a product of powers\n   of the system's base units with the proportionality factor of one.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "coherent unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subPropertyOf": [
      {
        "@id": "http://qudt.org/schema/qudt/hasDefinedUnit"
      }
    ]
  },
