      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/SystemOfUnits",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>System of Units</em> is a set of units which are chosen as the reference scales for some set of quantity kinds together with the definitions of each unit. \n  Units may be defined by experimental observation or by proportion to another unit not included in the system. \n  If the unit system is explicitly associated with a quantity kind system, then the unit system must define at least one unit for each quantity kind.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://qudt.org/schema/qudt/informativeReference": [
      {
        "@value": "http://dbpedia.org/resource/Category:Systems_of_units",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      },
      {
        "@value": "http://www.ieeeghn.org/wiki/index.php/System_of_Measurement_Units",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "System of Units"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
      {
        "@id": "http://qudt.org/schema/qudt/Verifiable"
      },
