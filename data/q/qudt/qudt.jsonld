      {
        "@value": "expression"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/fieldCode",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ],
    "http://qudt.org/schema/qudt/plainTextDescription": [
      {
        "@value": "\n  A field code is a generic property for representing unique codes that make up other identifiers. \n  For example each QuantityKind class caries a domain code as its field code.\n  "
