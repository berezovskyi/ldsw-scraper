  {
    "@id": "http://qudt.org/schema/qudt/ContextualUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Contextual Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Unit"
      },
      {
        "@id": "_:autos326"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/Unit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  A unit of measure, or unit, is a particular quantity value that has been chosen as a scale for measuring other quantities the same kind (more generally of equivalent dimension). \n  For example, the meter is a quantity of length that has been rigorously defined and standardized by the BIPM (International Board of Weights and Measures). \n  Any measurement of the length can be expressed as a number multiplied by the unit meter. \n  More formally, the value of a physical quantity Q with respect to a unit (U) is expressed as the scalar multiple of a real number (n) and U, as  $Q = nU$.\n  ",
        "@type": "http://qudt.org/schema/qudt/LatexString"
      }
    ],
    "http://qudt.org/schema/qudt/informativeReference": [
      {
        "@value": "http://dbpedia.org/resource/Category:Units_of_measure",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      },
      {
        "@value": "http://www.allmeasures.com/Fullconversion.asp",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
      {
        "@id": "http://qudt.org/schema/qudt/Verifiable"
      },
