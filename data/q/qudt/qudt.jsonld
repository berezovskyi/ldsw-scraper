    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  Scalar data types are those that have a single value. \n  The permissible values are defined over a domain that may be integers, float, character or boolean. \n  Often a scalar data type is referred to as a primitive data type.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
