  {
    "@id": "_:autos396",
    "@type": [
      "http://www.w3.org/2002/07/owl#Restriction"
    ],
    "http://www.w3.org/2002/07/owl#allValuesFrom": [
      {
        "@id": "http://qudt.org/schema/qudt/QuantityKindDimensionVector"
      }
    ],
    "http://www.w3.org/2002/07/owl#onProperty": [
      {
        "@id": "http://qudt.org/schema/qudt/hasDimensionVector"
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/QuantityKindDimensionVector",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n $\\text{Quantity Kind Dimension Vector}$ describes the dimensionality of a quantity kind in the context of a system of units. \n In the SI system of units, the dimensions of a quantity kind are expressed as a product of the basic\n  physical dimensions mass ($M$), length ($L$), time ($T$) current ($I$), amount of substance ($N$),\n   luminous intensity ($J$) and absolute temperature \n   ($\\theta$) as $dim \\, Q = L^{\\alpha} \\, M^{\\beta} \\, T^{\\gamma} \\, I ^{\\delta} \\, \\theta ^{\\epsilon} \\, N^{\\eta} \\, J ^{\\nu}$.\n\n\n  The rational powers of the dimensional exponents, $\\alpha, \\, \\beta, \\, \\gamma, \\, \\delta, \\, \\epsilon, \\, \\eta, \\, \\nu$, are positive, negative, or zero.\n\n  For example, the dimension of the physical quantity kind $\\it{speed}$ is $\\boxed{length/time}$, $L/T$ or $LT^{-1}$,\n   and the dimension of the physical quantity kind force is $\\boxed{mass \\times acceleration}$ or $\\boxed{mass \\times (length/time)/time}$, $ML/T^2$ or $MLT^{-2}$ respectively.\n ",
        "@type": "http://qudt.org/schema/qudt/LatexString"
      }
    ],
    "http://qudt.org/schema/qudt/informativeReference": [
      {
        "@value": "http://en.wikipedia.org/wiki/Dimensional_analysis",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      },
      {
        "@value": "http://web.mit.edu/2.25/www/pdf/DA_unified.pdf",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Quantity Kind Dimension Vector"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
      {
        "@id": "_:autos466"
      },
