  {
    "@id": "http://qudt.org/schema/qudt/udunitsCode",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "The UDUNITS package supports units of physical quantities. Its C library provides for arithmetic manipulation of units and for conversion of numeric values between compatible units. The package contains an extensive unit database, which is in XML format and user-extendable. The package also contains a command-line utility for investigating units and converting values.",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://purl.org/dc/terms/source": [
      {
        "@value": "https://www.unidata.ucar.edu/software/udunits/",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
