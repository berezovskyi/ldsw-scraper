  {
    "@id": "http://qudt.org/schema/qudt/BaseDimensionMagnitude",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  <p>A <em>Dimension</em> expresses a magnitude for a base quantity kind such as mass, length and time.\n  </p>\n  <p>DEPRECATED - each exponent is expressed as a property. \n  Keep until a validation of this has been done.\n  </p>",
        "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
      }
    ],
    "http://qudt.org/schema/qudt/informativeReference": [
      {
        "@value": "http://en.wikipedia.org/wiki/Dimensional_analysis",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      },
      {
        "@value": "http://web.mit.edu/2.25/www/pdf/DA_unified.pdf",
        "@type": "http://www.w3.org/2001/XMLSchema#anyURI"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Base Dimension Magnitude"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/Concept"
      },
