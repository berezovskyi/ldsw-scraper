  {
    "@id": "http://qudt.org/schema/qudt/SolidAngleUnit",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  The solid angle subtended by a surface S is defined as the surface area of a unit sphere covered by the surface S's projection onto the sphere. \n  A solid angle is related to the surface of a sphere in the same way an ordinary angle is related to the circumference of a circle. \n  Since the total surface area of the unit sphere is 4*pi, the measure of solid angle will always be between 0 and 4*pi.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Solid Angle Unit"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://qudt.org/schema/qudt/AngleUnit"
      }
    ]
  },
