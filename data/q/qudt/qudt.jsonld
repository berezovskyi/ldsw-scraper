  {
    "@id": "http://qudt.org/schema/qudt/latexSymbol",
    "@type": [
      "http://www.w3.org/2002/07/owl#DatatypeProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  The symbol is a glyph that is used to represent some concept, typically a unit or a quantity, in a compact form. \n  For example, the symbol for an Ohm is $ohm$. \n  This contrasts with 'unit:abbreviation', which gives a short alphanumeric abbreviation for the unit, 'ohm' for Ohm.\n  ",
        "@type": "http://qudt.org/schema/qudt/LatexString"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
        "@id": "http://qudt.org/schema/qudt"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "latex symbol"
      }
    ]
  },
  {
    "@id": "_:autos296",
