    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  This property relates a unit of measure to the system of units in which it is defined as a base unit for the system. \n  The base units of a system are used to define the derived units of the system by expressing the derived units as products of the base units raised to a rational power.\n  "
      }
    ],
    "http://www.w3.org/2002/07/owl#inverseOf": [
      {
        "@id": "http://qudt.org/schema/qudt/hasBaseUnit"
