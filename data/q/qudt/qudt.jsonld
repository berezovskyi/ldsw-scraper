    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  This property is used to identify a Quantity instance that is a measure of a change, or interval, of some property,\n   rather than a measure of its absolute value. \n  This is important for measurements such as temperature differences where the conversion among units would be calculated differently because of offsets.\n  "
      }
