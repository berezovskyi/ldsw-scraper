  {
    "@id": "http://qudt.org/schema/qudt/expression",
    "@type": [
      "http://www.w3.org/2002/07/owl#AnnotationProperty"
    ],
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  An 'expression' is a finite combination of symbols that are well-formed according to rules that apply to units of measure, quantity kinds and their dimensions.\n  "
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
