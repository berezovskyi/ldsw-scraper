  {
    "@id": "http://qudt.org/schema/qudt/BitEncodingType",
    "http://purl.org/dc/terms/description": [
      {
        "@value": "A bit encoding is a correspondence between the two possible values of a bit, 0 or 1, and some interpretation. For example, in a boolean encoding, a bit denotes a truth value, where 0 corresponds to False and 1 corresponds to True."
      }
    ],
    "http://www.w3.org/2002/07/owl#oneOf": [
      {
        "@list": [
          {
            "@id": "http://qudt.org/schema/qudt/BitEncoding"
          }
        ]
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/BooleanEncodingType",
    "http://www.w3.org/2002/07/owl#oneOf": [
      {
        "@list": [
          {
            "@id": "http://qudt.org/schema/qudt/BooleanEncoding"
          },
          {
            "@id": "http://qudt.org/schema/qudt/BitEncoding"
          },
          {
            "@id": "http://qudt.org/schema/qudt/OctetEncoding"
          }
        ]
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/CardinalityType",
    "http://purl.org/dc/terms/description": [
      {
        "@value": "\n  In mathematics, the cardinality of a set is a measure of the number of elements of the set.\n  For example, the set $A = {2, 4, 6}$ contains 3 elements, and therefore $A$ has a cardinality of 3. \n  There are two approaches to cardinality: one which compares sets directly using bijections and injections,\n   and another which uses cardinal numbers.\n  ",
        "@type": "http://qudt.org/schema/qudt/LatexString"
      }
    ],
    "http://www.w3.org/2002/07/owl#oneOf": [
      {
        "@list": [
          {
            "@id": "http://qudt.org/schema/qudt/CT_COUNTABLY-INFINITE"
          },
          {
            "@id": "http://qudt.org/schema/qudt/CT_FINITE"
          },
          {
            "@id": "http://qudt.org/schema/qudt/CT_UNCOUNTABLE"
          }
        ]
      }
    ]
  },
  {
    "@id": "http://qudt.org/schema/qudt/CharEncodingType",
    "http://purl.org/dc/terms/description": [
      {
        "@value": "The class of all character encoding schemes, each of which defines a rule or algorithm for encoding character data as a sequence of bits or bytes."
      }
    ],
    "http://www.w3.org/2002/07/owl#oneOf": [
      {
        "@list": [
          {
            "@id": "http://qudt.org/schema/qudt/CharEncoding"
